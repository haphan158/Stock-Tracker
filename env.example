# Database
POSTGRES_DB="stock_tracker"
POSTGRES_USER="postgres"
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD="replace-with-strong-password"
DATABASE_URL="postgresql://postgres:replace-with-strong-password@localhost:5432/stock_tracker"
DATABASE_URL_DOCKER="postgresql://postgres:replace-with-strong-password@db:5432/stock_tracker"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-32-plus-char-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stock data providers.
# Yahoo Finance is used by default and requires no key. If Yahoo rate-limits
# your IP, set FINNHUB_API_KEY (free tier: 60 calls/min) and the app will
# transparently fail over to Finnhub for quotes + history.
# Get one at https://finnhub.io/register
FINNHUB_API_KEY=""

# Alpha Vantage (legacy/unused, kept for reference)
ALPHA_VANTAGE_API_KEY=""

# AWS (for production deployment, optional)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
