# Database
POSTGRES_DB="stock_tracker"
POSTGRES_USER="postgres"
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD="replace-with-strong-password"
DATABASE_URL="postgresql://postgres:replace-with-strong-password@localhost:5432/stock_tracker"
# Used by Prisma migrations in production (e.g. Supabase direct connection).
DIRECT_URL="postgresql://postgres:replace-with-strong-password@localhost:5432/stock_tracker"
DATABASE_URL_DOCKER="postgresql://postgres:replace-with-strong-password@db:5432/stock_tracker"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-32-plus-char-random-secret"

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stock data providers.
# Yahoo Finance is used by default and requires no key. If Yahoo rate-limits
# your IP, set FINNHUB_API_KEY (free tier: 60 calls/min) to fall over to
# Finnhub for quotes and search. Get a key at https://finnhub.io/register
FINNHUB_API_KEY=""
# Twelve Data is the history (chart) fallback when Yahoo rate-limits. Finnhub
# removed /stock/candle from the free tier, so we can't rely on it for charts.
# Free tier: 800 requests/day, 8/min. Get a key at https://twelvedata.com/register
TWELVE_DATA_API_KEY=""
# 1 = print yahoo-finance2’s verbose crumb/cookie `console` output (very noisy in dev).
YAHOO_FINANCE_VERBOSE=""

# Observability
# Log level: one of fatal, error, warn, info, debug, trace, silent.
# Defaults: debug in dev, info in prod, silent in test.
LOG_LEVEL=""
# Short SHA injected at build/deploy time so /api/health can report the
# running commit. Example: GIT_SHA=$(git rev-parse --short HEAD) npm run build
GIT_SHA=""
# Sentry error reporting. Leave blank to disable; when set, Sentry is
# initialized on server, edge, and browser runtimes.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# 0.0 – 1.0 fraction of transactions captured for performance monitoring.
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
